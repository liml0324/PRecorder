<Window x:Class="PRecorder.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="460" Height="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 设置内容（可滚动） -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 保存路径 -->
                <TextBlock x:Name="lblSavePath" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtSavePath" Grid.Column="0" Margin="0,0,8,0"
                             VerticalAlignment="Center" IsReadOnly="True"/>
                    <Button x:Name="btnBrowse" Grid.Column="1" Width="70" Height="26"
                            Click="BtnBrowsePath_Click"/>
                </Grid>

                <!-- 保存格式 -->
                <TextBlock x:Name="lblFormat" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <ComboBox x:Name="cmbFormat" Margin="0,0,0,16" SelectedIndex="0"/>

                <!-- 缓冲区时长 -->
                <TextBlock x:Name="lblBufferDuration" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <ComboBox x:Name="cmbBufferDuration" Margin="0,0,0,16"/>

                <!-- 语言 -->
                <TextBlock x:Name="lblLanguage" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <ComboBox x:Name="cmbLanguage" Margin="0,0,0,16" SelectedIndex="0">
                    <ComboBoxItem Content="English"/>
                    <ComboBoxItem Content="中文 (Chinese)"/>
                </ComboBox>

                <!-- 关闭行为 -->
                <TextBlock x:Name="lblCloseBehavior" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <StackPanel Margin="0,0,0,8">
                    <RadioButton x:Name="rbTray" Margin="0,0,0,6"/>
                    <RadioButton x:Name="rbExit"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- 操作按钮（底部居中） -->
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,12,0,0">
            <Button x:Name="btnCancel" Width="80" Height="28"
                    Margin="0,0,12,0" Click="BtnCancel_Click" IsCancel="True"/>
            <Button x:Name="btnSave" Width="80" Height="28"
                    Click="BtnSave_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
