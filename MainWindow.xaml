<Window x:Class="PRecording.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="电钢琴后台预录制程序"
        Width="500" Height="340"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing"
        Loaded="Window_Loaded">

    <DockPanel Margin="14">
        <!-- 设备选择 -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="输入设备:" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="cmbDevice" Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <Button x:Name="btnRefreshDevices" Grid.Column="1" Content="刷新设备" Width="70"
                        Height="26" Click="BtnRefreshDevices_Click"/>
            </Grid>
        </StackPanel>

        <!-- 状态信息 -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
            <Border Background="#F0F4F8" Padding="12" CornerRadius="6">
                <StackPanel>
                    <!-- 录音状态 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Ellipse x:Name="statusDot" Width="12" Height="12" Fill="Gray"
                                 Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtStatus" Text="未开始录音" FontSize="14"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock x:Name="txtDuration" Text="已录制: --:--:--" Foreground="#555" Margin="0,0,0,3"/>
                    <TextBlock x:Name="txtBuffer" Text="缓冲区: 空" Foreground="#555" Margin="0,0,0,5"/>

                    <!-- 缓冲进度条 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ProgressBar x:Name="bufferBar" Grid.Column="0" Height="8"
                                     Minimum="0" Maximum="100" Value="0"/>
                        <TextBlock x:Name="txtBufferPct" Grid.Column="1" Text="0%"
                                   Width="36" TextAlignment="Right" FontSize="11"
                                   Foreground="#888" Margin="8,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- 操作按钮 -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,8,0,0">
            <Button x:Name="btnRecord" Content="▶  开始录音"
                    Width="110" Height="38" Margin="0,0,10,0"
                    FontSize="14" Click="BtnRecord_Click"/>
            <Button x:Name="btnSave" Content="💾  保存最近 5 分钟"
                    Width="150" Height="38" Margin="0,0,10,0"
                    FontSize="14" Click="BtnSave_Click" IsEnabled="False"/>
            <Button x:Name="btnExit" Content="退出"
                    Width="70" Height="38" FontSize="14"
                    Click="BtnExit_Click"/>
        </StackPanel>

        <!-- 底部状态栏 -->
        <StatusBar DockPanel.Dock="Bottom" Background="#E8ECF0">
            <StatusBarItem>
                <TextBlock x:Name="txtLastSave" Text="就绪" Foreground="#555"/>
            </StatusBarItem>
        </StatusBar>
    </DockPanel>
</Window>
